# ===========================================
# 医学考试平台 - 环境变量配置示例
# ===========================================

# 复制此文件为 .env 并填写实际值
# .env 文件不应该提交到 GitHub！

# ===========================================
# 数据库配置 (必需)
# ===========================================

# PostgreSQL 连接字符串
# 推荐使用 Neon PostgreSQL (https://neon.tech)
# 格式: postgresql://username:password@host/database?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ===========================================
# 安全配置 (必需)
# ===========================================

# JWT 密钥 - 用于生成登录 Token
# 建议使用至少 32 字符的随机字符串
# 可以使用 https://randomkeygen.com 生成
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===========================================
# 服务器配置 (可选)
# ===========================================

# 端口号 (默认 3000)
PORT=3000

# ===========================================
# 如何获取这些值？
# ===========================================

# 1. Neon PostgreSQL (推荐)
#    - 访问 https://neon.tech
#    - 注册/登录账号
#    - 创建新项目
#    - 在 Dashboard 中找到连接字符串

# 2. Supabase
#    - 访问 https://supabase.com
#    - 创建新项目
#    - 在 Settings -^> Database 中找到连接信息

# 3. Railway
#    - 访问 https://railway.app
#    - 创建 PostgreSQL 数据库
#    - 在数据库详情页找到连接字符串

# ===========================================
# Vercel 环境变量配置
# ===========================================

# 在 Vercel Dashboard 中配置：
# 1. 进入您的项目
# 2. 点击 Settings
# 3. 选择 Environment Variables
# 4. 添加以下变量：
#
# Name: DATABASE_URL
# Value: (您的 PostgreSQL 连接字符串)
#
# Name: JWT_SECRET
# Value: (您的随机密钥)
#
# 选择应用环境：Production, Preview, Development 全部勾选
# 点击 Save

# ===========================================
# 本地开发
# ===========================================

# 复制此文件为 .env
cp .env.example .env

# 编辑 .env 文件，填入实际值

# 本地运行服务器
npm run dev

# ===========================================
# 重要提醒
# ===========================================

# ⚠️ 绝对不要提交 .env 文件到 GitHub！
# ⚠️ 确保 .gitignore 包含 .env
# ⚠️ 生产环境使用强密码和随机密钥
# ⚠️ 定期轮换密钥以提高安全性

# ===========================================
